# ============================================================
# AtomQuest Goal Portal — Environment Variables (example)
# ============================================================
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored. Do NOT commit real keys.
# ============================================================


# --- Supabase (required) -----------------------------------
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only key. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# --- App URL (required) ------------------------------------
# Used inside email templates so links resolve to the live deployment.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000


# --- Resend (optional — emails no-op silently if unset) ----
# Sign up at https://resend.com → API Keys.
# Drives: sheet submitted / approved / returned notifications, check-in
# window reminders, and escalation emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx


# --- Cron auth (optional — recommended for production) -----
# Random secret used to authenticate GET /api/cron/escalations from
# Vercel Cron. If unset, only an authenticated admin session can hit
# the endpoint (Run-now button still works locally).
# Generate one: `openssl rand -hex 32`
CRON_SECRET=


# --- Microsoft Teams (optional — Teams cards no-op if unset) ---
# To enable Teams notifications for sheet submit / approve / return /
# escalations, set up a Workflow webhook in your Teams channel:
#   1. In Teams, open the target channel → ⋯ → Workflows
#   2. Pick "Post to a channel when a webhook request is received"
#   3. Click through the wizard, copy the resulting URL, paste below.
# The card includes a deep link back to the relevant page in AtomQuest.
TEAMS_WEBHOOK_URL=
